# Terraform runtime
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfplan
terraform/terraform.auto.tfvars.json

# Keep .terraform.lock.hcl versioned for reproducible provider/module initialization.
# Do not ignore .terraform.lock.hcl.

# Request files
# Keep only example request files in the public repository.
requests/*.tfvars.json
!requests/*.tfvars.example.json

# Local/bootstrap files
.env
*.local
*.local.*
setup/*.local.sh
setup/bootstrap-output.env
federated-credential*.json

# Azure CLI auth/cache
.azure/

# OS/Editor
.DS_Store
.vscode/
